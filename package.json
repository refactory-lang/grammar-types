{
  "name": "@refactory/grammar-types",
  "version": "0.1.0",
  "description": "Language-agnostic type projection from tree-sitter grammars to typed IR builders",
  "type": "module",
  "main": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "files": ["src"],
  "scripts": {
    "typecheck": "tsgo --noEmit",
