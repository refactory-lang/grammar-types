    "format": "oxfmt --config node_modules/@refactory/config-typescript/oxfmt.json ."
  },
  "devDependencies": {
    "@codemod.com/jssg-types": "^1.5.0",
    "@refactory/config-typescript": "github:refactory-lang/config-typescript",
    "@typescript/native-preview": "7.0.0-dev.20260317.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "type-fest": "^5.4.4",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@codemod.com/jssg-types": ">=1.5.0"
  },
  "packageManager": "pnpm@10.32.1"
}
